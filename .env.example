NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Producción: URL pública exacta (sin slash final). OAuth y emails deben coincidir con Supabase Redirect URLs.
# Ej: https://sprintal.vercel.app
NEXT_PUBLIC_APP_URL=

# Service role — SOLO en servidor, nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
